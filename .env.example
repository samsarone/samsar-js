NPM_TOKEN=npm_REPLACE_WITH_YOUR_TOKEN
PREFER_NPM_WEB_LOGIN=0

# Published versions are never auto-bumped by default. Set this only to resume
# Git/consumer propagation for the exact version already present on npm.
RESUME_PUBLISHED_VERSION=0
AUTO_BUMP_ON_PUBLISHED=0

# SDK release commit: explicit current branch -> remote/current branch.
GIT_PUSH=1
SAMSAR_JS_GIT_REMOTE=origin
SAMSAR_JS_RELEASE_BRANCH=
GIT_PROMOTE_MAIN=1
SAMSAR_JS_MAIN_BRANCH=main

# Canonical source consumers. Defaults include processor, generator, audio,
# AI-video, express listener, and assistant-query processor source projects.
GIT_PUSH_SAMSAR_ONE=1
SAMSAR_ONE_GIT_REMOTE=origin
SAMSAR_ONE_ROOTS=

# Standalone Gallery/Vercel propagation is production-affecting and opt-in.
SYNC_SAMSAR_GALLERY=0
GIT_PUSH_SAMSAR_GALLERY=1
SAMSAR_GALLERY_GIT_REMOTE=origin
SAMSAR_GALLERY_ROOT=
SAMSAR_GALLERY_REPOSITORY=https://github.com/samsarone/Gallery.git

# Sync canonical sources into the monorepo and promote develop/main. The sync
# script is invoked without --build, so it never rebuilds local Docker images.
SYNC_SAMSAR_MONOREPO=1
GIT_PUSH_SAMSAR_MONOREPO=1
SAMSAR_MONOREPO_ROOT=
SAMSAR_MONOREPO_SYNC_SCRIPT=
SAMSAR_MONOREPO_GIT_REMOTE=origin
SAMSAR_MONOREPO_DEVELOP_BRANCH=develop
SAMSAR_MONOREPO_MAIN_BRANCH=main
SAMSAR_MONOREPO_COMMIT_MESSAGE=
